{
  "manifest_version": 3,
  "name": "Lumina —  New Tab Page",
  "version": "1.3.1",
  "description": "A gorgeous new tab with AI search, quick links, a rich-text notes panel, saved reading list, weather, and animated backgrounds.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "bookmarks", "activeTab", "contextMenus", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://bible-api.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://api.open-meteo.com/*",
    "https://app.asana.com/*",
    "https://www.bing.com/*",
    "https://api.nasa.gov/*",
    "https://en.wikipedia.org/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["claude-ai.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["chatgpt.js"],
      "run_at": "document_idle"
    }
  ]
}
