#!/usr/bin/env bash
# Post-commit hook: if manifest.json version changed in this commit, build the
# extension zip into releases/<branch>/.
#
# Enable once per clone: git config core.hooksPath .githooks

set -euo pipefail

if ! git diff-tree --no-commit-id --name-only -r HEAD | grep -qx 'v1/manifest.json'; then
  exit 0
fi

NEW=$(git show "HEAD:v1/manifest.json" | jq -r .version 2>/dev/null || echo "")
OLD=$(git show "HEAD^:v1/manifest.json" 2>/dev/null | jq -r .version 2>/dev/null || echo "")

if [ -z "$NEW" ] || [ "$NEW" = "$OLD" ]; then
  exit 0
fi

BRANCH=$(git rev-parse --abbrev-ref HEAD)
OUT_DIR="releases/$BRANCH"

echo "[post-commit] manifest version $OLD -> $NEW, building zip into $OUT_DIR"

if ! command -v node >/dev/null 2>&1; then
  echo "[post-commit] node not found on PATH; skipping zip build" >&2
  exit 0
fi

cd v1

if [ ! -f tiptap-bundle.js ] || [ src/tiptap-bundle.js -nt tiptap-bundle.js ]; then
  echo "[post-commit] rebuilding tiptap bundle"
  npm run build --silent
fi

bash bin/build-zip.sh "../$OUT_DIR"
