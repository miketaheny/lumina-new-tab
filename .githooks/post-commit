#!/usr/bin/env bash
# Post-commit hook: builds extension zips when version changes are detected.
# - extension: triggers on extension/manifest.json version change
# - web: triggers on web/apps/extension/package.json version change
#
# Enable once per clone: git config core.hooksPath .githooks

set -euo pipefail

BRANCH=$(git rev-parse --abbrev-ref HEAD)
CHANGED_FILES=$(git diff-tree --no-commit-id --name-only -r HEAD)

# ─── Extension ─────────────────────────────────────────────────────────────────

if echo "$CHANGED_FILES" | grep -qx 'extension/manifest.json'; then
  NEW=$(git show "HEAD:extension/manifest.json" | jq -r .version 2>/dev/null || echo "")
  OLD=$(git show "HEAD^:extension/manifest.json" 2>/dev/null | jq -r .version 2>/dev/null || echo "")

  if [ -n "$NEW" ] && [ "$NEW" != "$OLD" ]; then
    OUT_DIR="releases/$BRANCH/extension"
    echo "[post-commit] extension manifest version $OLD -> $NEW, building zip into $OUT_DIR"

    if command -v node >/dev/null 2>&1; then
      (
        cd extension
        if [ ! -f tiptap-bundle.js ] || [ src/tiptap-bundle.js -nt tiptap-bundle.js ]; then
          echo "[post-commit] rebuilding tiptap bundle"
          npm run build --silent
        fi
        bash bin/build-zip.sh "../$OUT_DIR"
      )
    else
      echo "[post-commit] node not found on PATH; skipping extension zip build" >&2
    fi
  fi
fi

# ─── Web Extension ────────────────────────────────────────────────────────────

if echo "$CHANGED_FILES" | grep -qx 'web/apps/extension/package.json'; then
  NEW=$(git show "HEAD:web/apps/extension/package.json" | jq -r .version 2>/dev/null || echo "")
  OLD=$(git show "HEAD^:web/apps/extension/package.json" 2>/dev/null | jq -r .version 2>/dev/null || echo "")

  if [ -n "$NEW" ] && [ "$NEW" != "$OLD" ]; then
    OUT_DIR="releases/$BRANCH/web"
    echo "[post-commit] web extension version $OLD -> $NEW, building zip into $OUT_DIR"

    if command -v node >/dev/null 2>&1; then
      (
        cd web/apps/extension
        echo "[post-commit] running wxt build..."
        npx wxt build 2>&1 | tail -5
        mkdir -p "../../../$OUT_DIR"
        ZIP_PATH="../../../$OUT_DIR/lumina-new-tab-web-${NEW}.zip"
        rm -f "$ZIP_PATH"
        ( cd .output/chrome-mv3 && zip -r "$OLDPWD/$ZIP_PATH" . >/dev/null )
        echo "[post-commit] Built $ZIP_PATH"
      )
    else
      echo "[post-commit] node not found on PATH; skipping web zip build" >&2
    fi
  fi
fi
